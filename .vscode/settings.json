{
	"prettier.configPath": ".prettierrc",
	"editor.codeActionsOnSave": {
		"source.removeUnusedImports": "explicit"
	},
	"files.associations": {
		"*.css": "tailwindcss"
	},
	"editor.quickSuggestions": {
		"strings": "on"
	},
	"tailwindCSS.classAttributes": ["class", "ui"],
	"tailwindCSS.classFunctions": ["defineAppConfig"]
}
